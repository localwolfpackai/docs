{
  "openapi": "3.1.0",
  "info": {
    "title": "Tasks API",
    "description": "A simple task management API for agent-driven workflows. Create, list, and manage tasks programmatically.",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.example.com",
      "description": "Production"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/tasks": {
      "get": {
        "summary": "List all tasks",
        "description": "Returns all tasks the authenticated user has access to. Use the `limit` query parameter to control the number of results.",
        "operationId": "listTasks",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of results to return.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter by task status.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["pending", "in_progress", "completed"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of tasks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TaskWithId"
                  }
                },
                "example": [
                  {
                    "id": 1,
                    "title": "Set up MCP filesystem server",
                    "status": "completed",
                    "priority": "high"
                  },
                  {
                    "id": 2,
                    "title": "Write OpenAPI spec for webhook handler",
                    "status": "in_progress",
                    "priority": "medium"
                  }
                ]
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": 400,
                  "message": "Invalid status filter"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a new task",
        "description": "Creates a new task. The server assigns a unique ID and sets the initial status to `pending`.",
        "operationId": "createTask",
        "requestBody": {
          "description": "Task object to create",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Task"
              },
              "example": {
                "title": "Deploy docs site update",
                "priority": "high"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The newly created task",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskWithId"
                },
                "example": {
                  "id": 3,
                  "title": "Deploy docs site update",
                  "status": "pending",
                  "priority": "high"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": 400,
                  "message": "Title field is required"
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{id}": {
      "delete": {
        "summary": "Delete a task",
        "description": "Permanently deletes a task by ID. This action cannot be undone.",
        "operationId": "deleteTask",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID of the task to delete",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Task successfully deleted"
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": 400,
                  "message": "Task with the specified ID was not found"
                }
              }
            }
          }
        }
      }
    }
  },
  "webhooks": {
    "/tasks/webhook": {
      "post": {
        "summary": "Task created notification",
        "description": "Sent when a new task is created. Your endpoint should return a 200 status code to acknowledge receipt.",
        "operationId": "taskCreatedWebhook",
        "requestBody": {
          "description": "The task that was created",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskWithId"
              },
              "example": {
                "id": 3,
                "title": "Deploy docs site update",
                "status": "pending",
                "priority": "high"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Return 200 to acknowledge receipt"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Task": {
        "required": [
          "title"
        ],
        "type": "object",
        "description": "A task object for creating new entries",
        "properties": {
          "title": {
            "description": "What needs to be done",
            "type": "string",
            "example": "Set up MCP filesystem server"
          },
          "priority": {
            "description": "Task priority level",
            "type": "string",
            "enum": ["low", "medium", "high"],
            "example": "high"
          }
        }
      },
      "TaskWithId": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Task"
          },
          {
            "type": "object",
            "required": [
              "id",
              "status"
            ],
            "properties": {
              "id": {
                "description": "Unique identifier assigned by the server",
                "type": "integer",
                "format": "int64",
                "example": 1
              },
              "status": {
                "description": "Current task status",
                "type": "string",
                "enum": ["pending", "in_progress", "completed"],
                "example": "pending"
              }
            }
          }
        ],
        "description": "A task object returned from the API, including server-assigned ID and status"
      },
      "Error": {
        "required": [
          "error",
          "message"
        ],
        "type": "object",
        "description": "Error response returned when a request fails",
        "properties": {
          "error": {
            "description": "HTTP status code",
            "type": "integer",
            "format": "int32",
            "example": 400
          },
          "message": {
            "description": "Human-readable description of what went wrong",
            "type": "string",
            "example": "Unexpected error occurred"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Authenticate using a Bearer token in the Authorization header"
      }
    }
  }
}
